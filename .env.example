# ---- 101 Digital identity / API (server-only, NEVER expose to the browser) ----
# Base URL of the OAuth2 identity server (token exchange happens here, server-side only).
AUTH_BASE_URL=https://is-wso2-dev.101digital.io
# Base URL of the gateway hosting membership-service and invoice-service.
API_BASE_URL=https://api-neobank-dev.101digital.io

# OAuth2 application credentials. These are secrets and must stay server-side.
# Values for the shared sandbox are in the assessment PDF (Appendix A).
OAUTH_CLIENT_ID=your_client_id_here
OAUTH_CLIENT_SECRET=your_client_secret_here
OAUTH_SCOPE=openid

# ---- Session encryption (iron-session) ----
# Secret used to encrypt the session cookie. MUST be >= 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_PASSWORD=replace_with_a_random_string_at_least_32_chars_long
